//Num frames 


static volatile int currentFrame = 0;

// ========================= Forward Declarations =========================
void updatePWM();
void packBits(const uint8_t arr[64], uint32_t &lowOut, uint32_t &highOut);
void shiftOut64();
void enableHV();
void disableHV();
void parseSetCommand(const String &line);

// ========================= Setup =========================
void setup() {
  pinMode(PIN_SHIFT_EN, OUTPUT);   digitalWrite(PIN_SHIFT_EN, HIGH);
  pinMode(PIN_BLANK, OUTPUT);      digitalWrite(PIN_BLANK, HIGH);
  pinMode(PIN_SPI_LE, OUTPUT);     digitalWrite(PIN_SPI_LE, HIGH);
  pinMode(PIN_HV_EN, OUTPUT);      digitalWrite(PIN_HV_EN, LOW);
  pinMode(PIN_HV_CTRL, OUTPUT);    digitalWrite(PIN_HV_CTRL, LOW);

  SPI.begin();

  // init arrays
  for(int i=0; i<32; i++){
    desired[i] = 0;  // all off
  }
  for(int i=0; i<64; i++){
    vals[i] = 0;
  }

  Serial.begin(250000);
  delay(500);
  Serial.println("=== Detroit_Demo (No Partial in Demo) ===");
  Serial.println("By default, wave toggles odd/even at 1-second intervals with full on/off.");
  Serial.println("If user sends: SET 0 <pixel> <level> => we disable the wave.\n");

  // enableHV();
  Serial.println("HV supply enabled.");

  float periodMicros = 1e6f / (PWM_BASE_FREQ * SUBPHASES);
  pwmTimer.begin(updatePWM, periodMicros);
  Serial.println("Subphase timer ~60kHz begun.\n");

  pinMode(BUTTON_PIN, INPUT_PULLUP);  // Set the button pin as input with pull-up
}

// ========================= Main Loop =========================
#define DEBOUNCE_TIME 50  // Debounce time in milliseconds
#define STANDBY_TIME 10000  // Standby time in milliseconds

unsigned long lastDebounceTime = 0;
bool buttonState = HIGH;
bool lastButtonState = HIGH;

void loop() {
  // Read the current button state
  bool reading = digitalRead(BUTTON_PIN);

  // If the button state changed, due to noise or pressing
  if (reading != lastButtonState) {
    // Reset the debounce timer
    lastDebounceTime = millis();
  }
 // If enough time has passed since the last state change
  if ((millis() - lastDebounceTime) > STANDBY_TIME) {
    disableHV();
    psuON = false; 
  }
  // If enough time has passed since the last state change
  if ((millis() - lastDebounceTime) > DEBOUNCE_TIME) {
    // If the button state has changed
    if (reading != buttonState) {
      buttonState = reading;

      // Only trigger on button press (not release)
      if (buttonState == LOW) {
        demoMode++;
        if (demoMode > 4) {
          demoMode = 1;
        }

        currentFrame = 0;  // Reset frame counter
        subCount = 0;
        if (psuON == false) {
          enableHV(); 
          psuON = true;
        }

        // Start pre-reverse: reverse for 100ms, then auto-start demo
        demoActive = false;
        reverseActive = true;
        preReverseActive = true;
        reverseStartTime = millis();

        Serial.print("Demo mode is now ");
        if (demoMode == 1) {
          Serial.println("Up/Down Bar Demo");
        } else if (demoMode == 2) {
          Serial.println("Ball Rotation Demo");
        } else if (demoMode == 3) {
          Serial.println("Bouncing Ball Demo");
        } else {
          Serial.println("Left/Right Bar Demo");
        }
        Serial.println("Pre-reverse started...");
      }
    }
  }

  lastButtonState = reading;

  if(Serial.available()>0) {
    String line = Serial.readStringUntil('\n');
    line.trim();
    if(line.startsWith("SET ")) {
      // user command => disable wave demo
      demoMode = 0;
      parseSetCommand(line.substring(4));
      Serial.println("OK");
    }
    else if(line.length()>0) {
      // unknown
      Serial.print("Unknown cmd: ");
      Serial.println(line);
      Serial.println("Use: SET 0 <pixel> <level> ...");
    }
  }
}

// ========================= parseSetCommand =========================
// example: "0 10 4 15 0"
void parseSetCommand(const String &line) {
  char buf[128];
  line.toCharArray(buf, 128);

  int tokens[64];
  int tokenCount=0;
  char* p = strtok(buf," ");
  while(p && tokenCount<64) {
    tokens[tokenCount++] = atoi(p);
    p = strtok(NULL," ");
  }
  if(tokenCount<3) {
    Serial.println("Format error. e.g. SET 0 0 4 or SET 0 10 4 15 0");
    return;
  }
  int address = tokens[0];
  if(address!=0) {
    Serial.print("Invalid address: ");
    Serial.println(address);
    return;
  }

  // parse pairs
  if(((tokenCount - 1) % 2)!=0) {
    Serial.println("Pixel/level pairs mismatch!");
    return;
  }

  for(int i=1; i<tokenCount; i+=2) {
    int pix = tokens[i];
    int lvl = tokens[i+1];
    if(pix<0||pix>=32) {
      Serial.print("Pixel out of range: ");
      Serial.println(pix);
      continue;
    }
    if(lvl<0||lvl>4) {
      Serial.print("Level out of range: ");
      Serial.println(lvl);
      continue;
    }
    desired[pix] = lvl;
    Serial.print("Set Pixel #");
    Serial.print(pix);
    Serial.print(" => level ");
    Serial.println(lvl);
  }
}

// ========================= updatePWM() (Interrupt ~60kHz) =========================
// subphase logic => partial duty if user sets levels. 
// The built-in demo => toggles odd/even fully on/off every 1 second (60000 subphases).
void updatePWM() {
  pwm_phase = (pwm_phase + 1) % SUBPHASES; // 0..3

  if(demoMode == 1 && demoActive) {
    // Frame animation: demo 1 (Up/Down Bar)
    subCount++;
    if(subCount >= DEMO_INTERVAL_SUBPHASES) {
      subCount = 0;
      for(int i = 0; i < 32; i++) {
        desired[i] = demoFrames1[currentFrame][i];
      }
      currentFrame++;
      if(currentFrame >= NUM_FRAMES_1) {
        demoActive = false;
        currentFrame = 0;       // Reset for next time
        reverseActive = true;
        reverseStartTime = millis();
        Serial.println("Up/Down Bar demo completed. Starting reverse...");
      }
    }
  } else if(demoMode == 2 && demoActive) {
    // Frame animation: demo 2 (Ball Rotation)
    subCount++;
    if(subCount >= DEMO_INTERVAL_SUBPHASES) {
      subCount = 0;
      for(int i = 0; i < 32; i++) {
        desired[i] = demoFrames2[currentFrame][i];
      }
      currentFrame++;
      if(currentFrame >= NUM_FRAMES_2) {
        demoActive = false;
        currentFrame = 0;       // Reset for next time
        reverseActive = true;
        reverseStartTime = millis();
        Serial.println("Ball Rotation demo completed. Starting reverse...");
      }
    }
  } else if(demoMode == 3 && demoActive) {
    // Frame animation: demo 3 (Bouncing Ball)
    subCount++;
    if(subCount >= DEMO_INTERVAL_SUBPHASES) {
      subCount = 0;
      for(int i = 0; i < 32; i++) {
        desired[i] = demoFrames3[currentFrame][i];
      }
      currentFrame++;
      if(currentFrame >= NUM_FRAMES_3) {
        demoActive = false;
        currentFrame = 0;       // Reset for next time
        reverseActive = true;
        reverseStartTime = millis();
        Serial.println("Bouncing Ball demo completed. Starting reverse...");
      }
    }
  } else if(demoMode == 4 && demoActive) {
    // Frame animation: demo 4 (Left/Right Bar)
    subCount++;
    if(subCount >= DEMO_INTERVAL_SUBPHASES) {
      subCount = 0;
      for(int i = 0; i < 32; i++) {
        desired[i] = demoFrames4[currentFrame][i];
      }
      currentFrame++;
      if(currentFrame >= NUM_FRAMES_4) {
        demoActive = false;
        currentFrame = 0;       // Reset for next time
        reverseActive = true;
        reverseStartTime = millis();
        Serial.println("Left/Right Bar demo completed. Starting reverse...");
      }
    }
  }

  // Check if reverse mode should end
  if(reverseActive && (millis() - reverseStartTime >= REVERSE_DURATION_MS)) {
    reverseActive = false;
    for(int i = 0; i < 32; i++) {
      desired[i] = 0;
    }
    if(preReverseActive) {
      // Pre-reverse done: now start the demo
      preReverseActive = false;
      demoActive = true;
      subCount = 0;
      Serial.println("Pre-reverse done. Starting demo...");
    } else {
      Serial.println("Post-reverse completed.");
    }
  }

  // Apply valve commands based on mode
  for(int pix = 0; pix < 32; pix++) {
    if(reverseActive) {
      // REVERSE/DEFLATE mode: finger=1, reservoir=0 (vents air)
      vals[finger[pix]]    = 1;
      vals[reservoir[pix]] = 0;
    } else if(desired[pix] > pwm_phase) {
      // INFLATE mode: finger=0, reservoir=1
      vals[finger[pix]]    = 0;
      vals[reservoir[pix]] = 1;
    } else {
      // OFF mode: finger=0, reservoir=0
      vals[finger[pix]]    = 0;
      vals[reservoir[pix]] = 0;
    }
  }

  // pack & shift
  packBits(vals, outputLow, outputHigh);
  shiftOut64();
}

// ========================= packBits() =========================
void packBits(const uint8_t arr[64], uint32_t &lowOut, uint32_t &highOut) {
  uint32_t temp=0;
  // lower 32
  for(int j=0; j<32; j++){
    temp |= ((arr[j] & 1) << j);
  }
  lowOut = temp;

  temp=0;
  // upper 32
  for(int j=32; j<64; j++){
    temp |= ((arr[j] & 1) << (j-32));
  }
  highOut = temp;
}

// ========================= shiftOut64() =========================
void shiftOut64() {
  digitalWriteFast(PIN_SPI_LE, LOW);
  SPI.beginTransaction(hv507SPI);

  // low 32
  SPI.transfer(byte(outputLow >> 0));
  SPI.transfer(byte(outputLow >> 8));
  SPI.transfer(byte(outputLow >> 16));
  SPI.transfer(byte(outputLow >> 24));
  // high 32
  SPI.transfer(byte(outputHigh >> 0));
  SPI.transfer(byte(outputHigh >> 8));
  SPI.transfer(byte(outputHigh >> 16));
  SPI.transfer(byte(outputHigh >> 24));

  SPI.endTransaction();
  digitalWriteFast(PIN_SPI_LE, HIGH);
}

// ========================= HV Control =========================
void enableHV() {
  digitalWrite(PIN_HV_EN, HIGH);
  delay(1000); 
  digitalWrite(PIN_HV_CTRL, HIGH);
}

void disableHV() {
  digitalWrite(PIN_HV_EN, LOW);
  digitalWrite(PIN_HV_CTRL, LOW);
}
