// ========================= PWM Frequency =========================
// We'll keep the subphase approach: 15 kHz * 4 => ~60 kHz => 16.7us each subphase
// => 5 discrete duty steps (0..4) if the user sets partial levels.
// But the built-in "demo" uses only 0 (off) or 4 (full on).
#define PWM_BASE_FREQ 15000
#define SUBPHASES 4

// We'll store a "desired" level [0..4] for each pixel [0..31].
static volatile uint8_t desired[32];

// The 64 bits for our single HV507 driver:
uint8_t vals[64]; 
uint32_t outputLow, outputHigh; 

// subphase index 0..3
static volatile int pwm_phase = 0;
IntervalTimer pwmTimer;

// ========================= SPI Settings @ 8MHz =========================
