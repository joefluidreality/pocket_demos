        Serial.println("Frame Animation demo completed.");
      }
    }
  }else if(demoMode == 4 && demoActive) {
    // Third demo mode logic - frame animation
    subCount++;
    if(subCount >= DEMO_INTERVAL_SUBPHASES) {
      subCount = 0;
      
      // Apply the current frame
      for(int i = 0; i < 32; i++) {
        desired[i] = demoFrames4[currentFrame][i];
      }
      
      // Move to the next frame
      currentFrame++;
      
      // If we've shown all frames, stop the demo
      if(currentFrame >= NUM_FRAMES_4) {
        // Turn off all outputs
        for(int i = 0; i < 32; i++) {
          desired[i] = 0;
        }
        demoActive = false;
        currentFrame = 0;  // Reset for next time
        Serial.println("Frame Animation demo completed.");
      }
    }
  }//else if(demoMode == 5 && demoActive) {
  //   // Third demo mode logic - frame animation
  //   subCount++;
  //   if(subCount >= DEMO_INTERVAL_SUBPHASES) {
  //     subCount = 0;
      
  //     // Apply the current frame
  //     for(int i = 0; i < 32; i++) {
  //       desired[i] = demoFrames5[currentFrame][i];
  //     }
      
  //     // Move to the next frame
  //     currentFrame++;
      
  //     // If we've shown all frames, stop the demo
  //     if(currentFrame >= NUM_FRAMES_5) {
  //       // Turn off all outputs
  //       for(int i = 0; i < 32; i++) {
  //         desired[i] = 0;
  //       }
  //       demoActive = false;
  //       currentFrame = 0;  // Reset for next time
  //       Serial.println("Frame Animation demo completed.");
  //     }
  //   }
  // }

  // subphase partial logic
  for(int pix = 0; pix < 32; pix++) {
    if(desired[pix] > pwm_phase) {
      vals[currentActuator->finger[pix]]    = 0;
      vals[currentActuator->reservoir[pix]] = 1;
    } else {
      vals[currentActuator->finger[pix]]    = 0;
      vals[currentActuator->reservoir[pix]] = 0;
    }
  }

  // pack & shift
  packBits(vals, outputLow, outputHigh);
  shiftOut64();
}

// ========================= packBits() =========================
void packBits(const uint8_t arr[64], uint32_t &lowOut, uint32_t &highOut) {
  uint32_t temp=0;
  // lower 32
  for(int j=0; j<32; j++){
    temp |= ((arr[j] & 1) << j);
  }
  lowOut = temp;

  temp=0;
  // upper 32
  for(int j=32; j<64; j++){
    temp |= ((arr[j] & 1) << (j-32));
  }
  highOut = temp;
}

// ========================= shiftOut64() =========================
void shiftOut64() {
  digitalWriteFast(PIN_SPI_LE, LOW);
  SPI.beginTransaction(hv507SPI);

  // low 32
  SPI.transfer(byte(outputLow >> 0));
  SPI.transfer(byte(outputLow >> 8));
  SPI.transfer(byte(outputLow >> 16));
  SPI.transfer(byte(outputLow >> 24));
  // high 32
  SPI.transfer(byte(outputHigh >> 0));
  SPI.transfer(byte(outputHigh >> 8));
  SPI.transfer(byte(outputHigh >> 16));
  SPI.transfer(byte(outputHigh >> 24));

  SPI.endTransaction();
  digitalWriteFast(PIN_SPI_LE, HIGH);
}

// ========================= HV Control =========================
void enableHV() {
  digitalWrite(PIN_HV_EN, HIGH);
  delay(1000); 
  digitalWrite(PIN_HV_CTRL, HIGH);
}

void disableHV() {
  digitalWrite(PIN_HV_EN, LOW);
  digitalWrite(PIN_HV_CTRL, LOW);
}
