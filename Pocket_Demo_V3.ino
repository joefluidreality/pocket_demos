// ========================= Setup =========================
void setup() {
  pinMode(PIN_SHIFT_EN, OUTPUT);   digitalWrite(PIN_SHIFT_EN, HIGH);
  pinMode(PIN_BLANK, OUTPUT);      digitalWrite(PIN_BLANK, HIGH);
  pinMode(PIN_SPI_LE, OUTPUT);     digitalWrite(PIN_SPI_LE, HIGH);
  pinMode(PIN_HV_EN, OUTPUT);      digitalWrite(PIN_HV_EN, LOW);
  pinMode(PIN_HV_CTRL, OUTPUT);    digitalWrite(PIN_HV_CTRL, LOW);

  SPI.begin();

  // init arrays
  for(int i=0; i<32; i++){
    desired[i] = 0;  // all off
  }
  for(int i=0; i<64; i++){
    vals[i] = 0;
  }

  Serial.begin(250000);
  delay(500);
  Serial.println("=== Detroit_Demo (No Partial in Demo) ===");
  Serial.println("By default, wave toggles odd/even at 1-second intervals with full on/off.");
  Serial.println("If user sends: SET 0 <pixel> <level> => we disable the wave.\n");

  // enableHV();
  Serial.println("HV supply enabled.");

  float periodMicros = 1e6f / (PWM_BASE_FREQ * SUBPHASES);
  pwmTimer.begin(updatePWM, periodMicros);
  Serial.println("Subphase timer ~60kHz begun.\n");

  pinMode(BUTTON_PIN, INPUT_PULLUP);  // Set the button pin as input with pull-up
}

// ========================= Main Loop =========================
#define DEBOUNCE_TIME 50  // Debounce time in milliseconds
#define STANDBY_TIME 10000  // Standby time in milliseconds

unsigned long lastDebounceTime = 0;
bool buttonState = HIGH;
bool lastButtonState = HIGH;

void loop() {
  // Read the current button state
  bool reading = digitalRead(BUTTON_PIN);

  // If the button state changed, due to noise or pressing
  if (reading != lastButtonState) {
    // Reset the debounce timer
    lastDebounceTime = millis();
  }
 // If enough time has passed since the last state change
  if ((millis() - lastDebounceTime) > STANDBY_TIME) {
    disableHV();
    psuON = false; 
  }
  // If enough time has passed since the last state change
  if ((millis() - lastDebounceTime) > DEBOUNCE_TIME) {
    // If the button state has changed
    if (reading != buttonState) {
      buttonState = reading;

      // Only trigger on button press (not release)
      if (buttonState == LOW) {
        demoMode++;
        if (demoMode > 4) {
          demoMode = 1;
          // disableHV(); 
        }

        currentFrame = 0;  // Reset frame counter
        if (psuON == false) {
          enableHV(); 
          psuON = true;
        }
        demoActive = true;         
        Serial.print("Demo mode is now ");
        if (demoMode == 1) {
          Serial.println("Pattern Demo");
        } else if (demoMode == 2) {
          Serial.println("Circular Demo");
        } else {
          Serial.println("Frame Animation Demo");
        }
      }
    }
  }

  lastButtonState = reading;

  if(Serial.available()>0) {
    String line = Serial.readStringUntil('\n');
    line.trim();
    if(line.startsWith("SET ")) {
      // user command => disable wave demo
      demoMode = 0;
      parseSetCommand(line.substring(4));
      Serial.println("OK");
    }
    else if(line.length()>0) {
      // unknown
      Serial.print("Unknown cmd: ");
      Serial.println(line);
      Serial.println("Use: SET 0 <pixel> <level> ...");
    }
  }
}

// ========================= parseSetCommand =========================
// example: "0 10 4 15 0"
void parseSetCommand(const String &line) {
  char buf[128];
  line.toCharArray(buf, 128);

  int tokens[64];
  int tokenCount=0;
  char* p = strtok(buf," ");
  while(p && tokenCount<64) {
    tokens[tokenCount++] = atoi(p);
    p = strtok(NULL," ");
  }
  if(tokenCount<3) {
    Serial.println("Format error. e.g. SET 0 0 4 or SET 0 10 4 15 0");
    return;
  }
  int address = tokens[0];
  if(address!=0) {
    Serial.print("Invalid address: ");
    Serial.println(address);
    return;
  }

  // parse pairs
  if(((tokenCount - 1) % 2)!=0) {
    Serial.println("Pixel/level pairs mismatch!");
    return;
  }

  for(int i=1; i<tokenCount; i+=2) {
    int pix = tokens[i];
    int lvl = tokens[i+1];
    if(pix<0||pix>=32) {
      Serial.print("Pixel out of range: ");
      Serial.println(pix);
      continue;
    }
    if(lvl<0||lvl>4) {
      Serial.print("Level out of range: ");
      Serial.println(lvl);
      continue;
    }
    desired[pix] = lvl;
    Serial.print("Set Pixel #");
    Serial.print(pix);
    Serial.print(" => level ");
    Serial.println(lvl);
  }
}

// ========================= updatePWM() (Interrupt ~60kHz) =========================
// subphase logic => partial duty if user sets levels. 
// The built-in demo => toggles odd/even fully on/off every 1 second (60000 subphases).
void updatePWM() {
  pwm_phase = (pwm_phase + 1) % SUBPHASES; // 0..3

  if(demoMode == 1 && demoActive) {
    // First demo mode logic - frame animation
    subCount++;
    if(subCount >= DEMO_INTERVAL_SUBPHASES) {
      subCount = 0;
      
      // Apply the current frame
      for(int i = 0; i < 32; i++) {
        desired[i] = demoFrames1[currentFrame][i];
      }
      
      // Move to the next frame
      currentFrame++;
      
      // If we've shown all frames, stop the demo
      if(currentFrame >= NUM_FRAMES_1) {
        // Turn off all outputs
        for(int i = 0; i < 32; i++) {
          desired[i] = 0;
        }
        demoActive = false;
        currentFrame = 0;  // Reset for next time
        Serial.println("Pattern demo completed.");
      }
    }
  } else if(demoMode == 2 && demoActive) {
    // Second demo mode logic - frame animation
    subCount++;
    if(subCount >= DEMO_INTERVAL_SUBPHASES) {
      subCount = 0;
      
      // Apply the current frame
      for(int i = 0; i < 32; i++) {
        desired[i] = demoFrames2[currentFrame][i];
      }
      
      // Move to the next frame
      currentFrame++;
      
      // If we've shown all frames, stop the demo
      if(currentFrame >= NUM_FRAMES_2) {
        // Turn off all outputs
        for(int i = 0; i < 32; i++) {
          desired[i] = 0;
        }
